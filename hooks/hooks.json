{
  "description": "Request a safe rollover at a configured context threshold.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/stop.mjs\" --plugin-data-config",
            "commandWindows": "node \"%PLUGIN_ROOT%\\hooks\\stop.mjs\" --plugin-data-config",
            "timeout": 30,
            "statusMessage": "Checking configured context rollover threshold"
          }
        ]
      }
    ]
  }
}
